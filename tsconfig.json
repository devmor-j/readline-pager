{
  "include": ["src"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "sourceMap": false,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "emitDeclarationOnly": false
  }
}
