{
  "name": "readline-pager",
  "version": "0.2.1",
  "scripts": {
    "build": "tsdown",
    "pretest": "npm run build",
    "test": "node --test --experimental-test-coverage test/**/*.test.ts",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "~25.3.0",
    "prettier": "~3.8.1",
    "prettier-plugin-organize-imports": "~4.3.0",
    "tsdown": "~0.20.3",
    "typescript": "~5.9.3"
  },
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    ".": {
      "require": "./dist/main.cjs",
      "import": "./dist/main.mjs",
      "types": "./dist/main.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nodejs",
    "readline",
    "readline-pager",
    "pager",
    "file-reader",
    "pagination",
    "large-files",
    "async-iterator",
    "streaming",
    "memory-efficient",
    "high-performance",
    "log-processing",
    "backward-reading"
  ],
  "description": "Memory-efficient, paginated file reader for Node.js with async iteration, prefetching, backward reading and optional worker support.",
  "engines": {
    "node": ">=18.12"
  },
  "author": "Morteza Jamshidi",
  "license": "MIT"
}
