{
  "name": "readline-pager",
  "version": "0.6.5",
  "scripts": {
    "build:js": "tsdown",
    "build:native": "node-gyp rebuild",
    "build": "npm run build:native && npm run build:js",
    "pretest": "npm run build",
    "test": "PAGER_TEST_CLEANUPS=1 node --test --experimental-test-coverage test/**/*.test.ts",
    "prepublishOnly": "npm run build && npm run test",
    "benchmark:node": "node test/benchmark.ts",
    "benchmark:deno": "deno --allow-write --allow-read --allow-env test/benchmark.ts",
    "benchmark:bun": "bun test/benchmark.ts"
  },
  "devDependencies": {
    "@types/bun": "~1.3.11",
    "@types/deno": "~2.5.0",
    "@types/node": "~25.5.0",
    "node-gyp": "~12.2.0",
    "prettier": "~3.8.1",
    "prettier-plugin-organize-imports": "~4.3.0",
    "tsdown": "~0.21.6",
    "typescript": "~6.0.2"
  },
  "optionalDependencies": {
    "@devmor-j/readline-pager-linux-arm64": "0.6.5",
    "@devmor-j/readline-pager-linux-musl-arm64": "0.6.5",
    "@devmor-j/readline-pager-linux-musl-x64": "0.6.5",
    "@devmor-j/readline-pager-linux-x64": "0.6.5"
  },
  "gypfile": false,
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    ".": {
      "require": "./dist/main.cjs",
      "import": "./dist/main.mjs",
      "types": "./dist/main.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nodejs",
    "readline-pager",
    "file-reader",
    "pagination",
    "large-files",
    "async-iterator",
    "streaming",
    "memory-efficient",
    "high-performance",
    "log-processing",
    "backward-reading",
    "native-addon",
    "cpp",
    "avx2",
    "neon"
  ],
  "description": "High-performance paginated file reader for Node.js. Efficiently process large text files without loading them into memory.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devmor-j/readline-pager.git"
  },
  "homepage": "https://github.com/devmor-j/readline-pager#readme",
  "bugs": {
    "url": "https://github.com/devmor-j/readline-pager/issues"
  },
  "engines": {
    "node": ">=18.12"
  },
  "author": "Morteza Jamshidi",
  "license": "MIT"
}
