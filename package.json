{
  "name": "readline-pager",
  "version": "0.3.0",
  "scripts": {
    "build:js": "tsdown",
    "build:native": "prebuildify --napi --strip && rm -rf ./build",
    "build": "npm run build:native && npm run build:js",
    "pretest": "npm run build",
    "test": "node --test --experimental-test-coverage test/**/*.test.ts",
    "prepublishOnly": "npm run build && npm run test",
    "benchmark": "node test/_benchmark.ts; bun test/_benchmark.ts; deno --allow-write --allow-read test/_benchmark.ts"
  },
  "devDependencies": {
    "@types/bun": "~1.3.11",
    "@types/deno": "~2.5.0",
    "@types/node": "~25.5.0",
    "node-gyp": "~12.2.0",
    "prebuildify": "~6.0.1",
    "prettier": "~3.8.1",
    "prettier-plugin-organize-imports": "~4.3.0",
    "tsdown": "~0.21.4",
    "typescript": "~5.9.3"
  },
  "gypfile": false,
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    ".": {
      "require": "./dist/main.cjs",
      "import": "./dist/main.mjs",
      "types": "./dist/main.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nodejs",
    "readline",
    "readline-pager",
    "pager",
    "file-reader",
    "pagination",
    "large-files",
    "async-iterator",
    "streaming",
    "memory-efficient",
    "high-performance",
    "log-processing",
    "backward-reading"
  ],
  "description": "Memory-efficient, paginated file reader for Node.js with async iteration, prefetching, backward reading and optional worker support.",
  "engines": {
    "node": ">=18.12"
  },
  "author": "Morteza Jamshidi",
  "license": "MIT"
}
